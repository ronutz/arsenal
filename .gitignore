# ============================================================================
# .gitignore — arsenal (ronutz.com)
# Keeps build artifacts, dependencies, and secrets OUT of the repo. Everything
# else (source, config, package-lock, public assets) is committed and is what
# Cloudflare builds from.
# ============================================================================

# Dependencies (reinstalled via `npm install` on every build)
/node_modules

# Next.js build output (regenerated by `next build` + pagefind)
/.next/
/out/

# Other build dirs
/build

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files — NEVER commit secrets
.env
.env*.local

# Editor / OS cruft
.DS_Store
*.pem
*.tsbuildinfo

# Next.js auto-generates this on build; not committed
next-env.d.ts

# Deploy platforms
.vercel

# Generated OG social-preview cards (built in CI prebuild by scripts/gen-og.mts)
/public/og/
